<%- include('partials/header', { title, user }) %>
<main class="main-content">
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">Open Source License Management</div>
        <h1 class="hero-title">The better way to <span class="gradient-text">manage</span> your application licenses</h1>
        <p class="hero-subtitle">Generate, validate, and manage license keys for your software with a simple REST API. Secure your apps with HWID locking, expiration dates, and real-time logging.</p>
        <div class="hero-actions">
          <a href="/register" class="btn btn-lg btn-primary">Get Started Free</a>
          <a href="/docs" class="btn btn-lg btn-outline">View Documentation</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-value">REST API</span>
            <span class="stat-label">Simple Integration</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">HWID Lock</span>
            <span class="stat-label">Device Binding</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">Real-time</span>
            <span class="stat-label">Activity Logs</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="code-block">
          <div class="code-header">
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <span class="code-lang">POST /api/verify</span>
          </div>
          <div class="code-body">
            <pre><span class="code-key">fetch</span>(<span class="code-str">'/api/verify'</span>, {<br>  method: <span class="code-str">'POST'</span>,<br>  headers: { <span class="code-str">'X-API-Key'</span>: <span class="code-str">'lic_...'</span> },<br>  body: JSON.stringify({<br>    license_key: <span class="code-str">'XXXX-XXXX-XXXX'</span>,<br>    hwid: <span class="code-str">'device-fingerprint'</span><br>  })<br>})<br><span class="code-comment">// Response: { valid: true, status: "VALID" }</span></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <h2>Everything you need to secure your software</h2>
        <p>Powerful features designed to make license management simple and secure.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔑</div>
          <h3>License Generation</h3>
          <p>Generate cryptographically secure license keys with custom prefixes, expiration dates, and bulk creation.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🖥️</div>
          <h3>HWID Locking</h3>
          <p>Bind licenses to specific hardware IDs to prevent sharing. Each license locked to one machine.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⏱️</div>
          <h3>Expiry Management</h3>
          <p>Set expiration dates, create lifetime licenses, or implement subscription-based models.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Dashboard</h3>
          <p>Full web dashboard to manage apps, licenses, and users with real-time statistics.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📝</div>
          <h3>Activity Logs</h3>
          <p>Track every verification, activation, and failed attempt with detailed logging.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🚫</div>
          <h3>Ban Management</h3>
          <p>Instantly ban or unban license keys. Block users by HWID or IP address.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="api-demo">
    <div class="container">
      <div class="section-header">
        <h2>Simple REST API</h2>
        <p>Integrate in minutes with our straightforward API.</p>
      </div>
      <div class="demo-grid">
        <div class="demo-card">
          <div class="demo-card-header">Verify License</div>
          <pre>POST /api/verify
X-API-Key: your_api_key

{
  "license_key": "KEY-ABCD1234",
  "hwid": "device_id"
}</pre>
        </div>
        <div class="demo-card">
          <div class="demo-card-header">Activate License</div>
          <pre>POST /api/activate
X-API-Key: your_api_key

{
  "license_key": "KEY-ABCD1234",
  "hwid": "device_id",
  "owner": "user@example.com"
}</pre>
        </div>
        <div class="demo-card">
          <div class="demo-card-header">Check Status</div>
          <pre>POST /api/check
X-API-Key: your_api_key

{
  "license_key": "KEY-ABCD1234"
}</pre>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Ready to secure your applications?</h2>
      <p>Start for free. No credit card required. Deploy on your own server.</p>
      <a href="/register" class="btn btn-lg btn-primary">Create Your Account</a>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
